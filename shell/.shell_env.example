# ============================================================
# 共享环境变量（bash 和 zsh 通用）
# 复制此文件为 ~/.shell_env 并填入你的真实值：
#   cp shell/.shell_env.example ~/.shell_env
# ============================================================

# ---- macOS 特有 PATH（Linux 不需要这行，可删除） ----
# macOS 的 pip install --user 安装到 ~/Library/Python/x.x/bin
# 取消注释并修改 Python 版本号：
# export PATH="$HOME/Library/Python/3.9/bin:$PATH"

# ---- Linux 特有 PATH ----
# AppImage 和 pip install --user 安装到 ~/.local/bin
# install.sh 会自动在 .bashrc 中添加，此处不需要重复

# ---- Claude Code API 配置 ----
export ANTHROPIC_API_KEY="your-api-key-here"
export ANTHROPIC_AUTH_TOKEN="your-api-key-here"
export ANTHROPIC_BASE_URL="https://your-api-endpoint.com"
export ANTHROPIC_MODEL="your-model-name"
export ANTHROPIC_DEFAULT_OPUS_MODEL="your-model-name"
export CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# ---- 自定义代理（如果网络受限，取消注释并填入代理地址） ----
# export HTTP_PROXY="http://proxy:port"
# export HTTPS_PROXY="http://proxy:port"
# export ALL_PROXY="socks5://proxy:port"
